{
  "entities": {
    "User": {
      "title": "User",
      "description": "User statistics and profile data including AI vs Player Challenge tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "totalGames": { "type": "number" },
        "avatarConfig": {
          "type": "object",
          "properties": {
            "icon": { "type": "string" },
            "color": { "type": "string" }
          }
        },
        "hasAiChallengeEntry": { "type": "boolean" },
        "aiChallengeGamesPlayed": { "type": "number" },
        "aiChallengeWins": { "type": "number" },
        "usdtWalletAddress": { "type": "string" },
        "aiChallengeCompleted": { "type": "boolean" },
        "aiChallengeSuccess": { "type": "boolean" },
        "aiChallengeJoinedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "wins", "losses"]
    },
    "GlobalMessage": {
      "title": "Global Message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "avatar": {
          "type": "object",
          "properties": {
            "icon": { "type": "string" },
            "color": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    },
    "Replay": {
      "title": "Replay",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gridWidth": { "type": "number" },
        "gridHeight": { "type": "number" },
        "players": { "type": "array" },
        "moves": { "type": "array" },
        "winnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "gridWidth", "gridHeight", "players", "moves", "createdAt"]
    },
    "Tournament": {
      "title": "Tournament",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prize": { "type": "number" },
        "playersCount": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "prize", "playersCount", "maxPlayers", "status"]
    },
    "TournamentRecord": {
      "title": "Tournament Record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatar": {
          "type": "object",
          "properties": {
            "icon": { "type": "string" },
            "color": { "type": "string" }
          }
        },
        "score": { "type": "number" },
        "rank": { "type": "number" },
        "status": { "type": "string" },
        "chancesUsed": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "score", "status", "chancesUsed", "joinedAt"]
    }
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament"
    },
    "/tournament_participants/{recordId}": {
      "schema": "TournamentRecord"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profile and match statistics."
    },
    "/global_messages/{messageId}": {
      "schema": "GlobalMessage",
      "description": "Global chat messages."
    },
    "/replays/{replayId}": {
      "schema": "Replay",
      "description": "Recorded match replays."
    }
  }
}
