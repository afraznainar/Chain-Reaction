rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation for User entity
    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 64 &&
             data.wins is number && data.wins >= 0 &&
             data.losses is number && data.losses >= 0 &&
             data.totalGames is number && data.totalGames >= 0;
    }

    match /users/{userId} {
      // Allow anybody to view the leaderboard (list/get)
      allow read: if isSignedIn();
      
      // Only the owner can initialize or update their own stats
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().userId == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['wins', 'losses', 'totalGames', 'displayName', 'photoURL', 'updatedAt', 'avatarConfig'])
      );
    }

    match /global_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && incoming().text.size() <= 280;
    }

    match /replays/{replayId} {
      allow read: if true;
      allow create: if true; // In a production app, restrict this, but for now we allow server-side saves or client-side if needed
    }
  }
}
